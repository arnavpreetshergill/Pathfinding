{
  "name": "offline-routing-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open",
    "build": "ng build --configuration production",
    "electron": "ng build && electron .",
    "electron-dev": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron . --dev\"",
    "test": "ng test",
    "pack": "ng build && electron-builder --dir",
    "build-linux": "ng build && electron-builder --linux tar.gz",
    "build-win": "ng build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.drdo.offlinerouter",
    "files": [
      "dist/offline-routing-desktop/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "tar.gz",
      "category": "Utility"
    },
    "extraResources": [
      {
        "from": "offline-map-data",
        "to": "offline-map-data",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@angular/animations": "^18.0.0",
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "@angular/platform-browser": "^18.0.0",
    "@angular/platform-browser-dynamic": "^18.0.0",
    "leaflet": "^1.9.4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.0.0",
    "@angular/cli": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "@types/leaflet": "^1.9.12",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "~5.4.2",
    "wait-on": "^7.0.1"
  }
}